<UserControl x:Class="Cad_AI_Agent.UI.AIChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="560"
             Background="#1A1A1A"
             FontFamily="Segoe UI">
   <UserControl.Resources>
       <!-- === Industrial Gray Palette === -->
       <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#1A1A1A"/>
       <SolidColorBrush x:Key="SurfaceBrush"         Color="#212121"/>
       <SolidColorBrush x:Key="SidebarBrush"         Color="#141414"/>
       <SolidColorBrush x:Key="CardBrush"            Color="#272727"/>
       <SolidColorBrush x:Key="CardAltBrush"         Color="#2D2D2D"/>
       <SolidColorBrush x:Key="BorderBrushDark"      Color="#383838"/>
       <!-- Amber accent — industrial / engineering feel -->
       <SolidColorBrush x:Key="AccentBrush"          Color="#E8A000"/>
       <SolidColorBrush x:Key="AccentBrushDark"      Color="#C47E00"/>
       <SolidColorBrush x:Key="AccentSubtle"         Color="#2A2000"/>
       <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#E0E0E0"/>
       <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#888888"/>
       <SolidColorBrush x:Key="SuccessBrush"         Color="#6FCF97"/>

       <!-- ── Sidebar button ── -->
       <Style x:Key="SidebarButtonStyle" TargetType="Button">
           <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderBrush" Value="Transparent"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="Padding" Value="12,10"/>
           <Setter Property="HorizontalContentAlignment" Value="Left"/>
           <Setter Property="VerticalContentAlignment" Value="Center"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="Button">
                       <Border x:Name="border"
                               Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}"
                               CornerRadius="6"
                               SnapsToDevicePixels="True">
                           <ContentPresenter Margin="{TemplateBinding Padding}"
                                             HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                             VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="border" Property="Background" Value="#2E2E2E"/>
                           </Trigger>
                           <Trigger Property="IsPressed" Value="True">
                               <Setter TargetName="border" Property="Background" Value="#363636"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter Property="Opacity" Value="0.45"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <!-- ── Top tab button ── -->
       <Style x:Key="TopTabButtonStyle" TargetType="Button">
           <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="FontWeight" Value="SemiBold"/>
           <Setter Property="Padding" Value="14,7"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="Button">
                       <Border x:Name="border"
                               Background="#2A2A2A"
                               BorderBrush="#3A3A3A"
                               BorderThickness="1"
                               CornerRadius="6">
                           <ContentPresenter HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Margin="{TemplateBinding Padding}"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="border" Property="Background" Value="#323232"/>
                               <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                           </Trigger>
                           <Trigger Property="IsPressed" Value="True">
                               <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <!-- ── Primary (amber) button ── -->
       <Style x:Key="PrimaryButtonStyle" TargetType="Button">
           <Setter Property="Foreground" Value="#1A1200"/>
           <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="Padding" Value="14,10"/>
           <Setter Property="FontWeight" Value="Bold"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="Button">
                       <Border x:Name="border"
                               Background="{TemplateBinding Background}"
                               CornerRadius="6">
                           <ContentPresenter HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Margin="{TemplateBinding Padding}"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="border" Property="Background" Value="#F0AC00"/>
                           </Trigger>
                           <Trigger Property="IsPressed" Value="True">
                               <Setter TargetName="border" Property="Background" Value="#C47E00"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter Property="Opacity" Value="0.45"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <!-- ── Secondary (ghost) button ── -->
       <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
           <Setter Property="Background" Value="#2A2A2A"/>
           <Setter Property="BorderBrush" Value="#3A3A3A"/>
           <Setter Property="BorderThickness" Value="1"/>
           <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
           <Setter Property="HorizontalContentAlignment" Value="Center"/>
       </Style>

       <!-- ── Input text box ── -->
       <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
           <Setter Property="Background" Value="#1E1E1E"/>
           <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
           <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
           <Setter Property="BorderBrush" Value="#3A3A3A"/>
           <Setter Property="BorderThickness" Value="1"/>
           <Setter Property="Padding" Value="12,10"/>
           <Setter Property="FontSize" Value="13"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="TextBox">
                       <Border x:Name="border"
                               Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}"
                               CornerRadius="6">
                           <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsKeyboardFocused" Value="True">
                               <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter Property="Opacity" Value="0.5"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>

       <!-- ── Section label ── -->
       <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
           <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
           <Setter Property="FontSize" Value="11"/>
           <Setter Property="FontWeight" Value="SemiBold"/>
           <Setter Property="Margin" Value="0,0,0,5"/>
       </Style>

       <!-- ── ComboBox item ── -->
       <Style x:Key="DarkComboItemStyle" TargetType="ComboBoxItem">
           <Setter Property="Background" Value="#272727"/>
           <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
           <Setter Property="Padding" Value="12,9"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="ComboBoxItem">
                       <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                           <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsHighlighted" Value="True">
                               <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                           </Trigger>
                           <Trigger Property="IsSelected" Value="True">
                               <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrushDark}"/>
                               <Setter Property="Foreground" Value="#1A1200"/>
                           </Trigger>
                           <Trigger Property="IsEnabled" Value="False">
                               <Setter Property="Foreground" Value="#555555"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>
   </UserControl.Resources>

   <!-- Root border — 1 px charcoal edge, no large rounding -->
   <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="0">
       <Grid>
           <Grid.ColumnDefinitions>
               <ColumnDefinition Width="186" x:Name="SidebarColumn"/>
               <ColumnDefinition Width="1"/>
               <ColumnDefinition Width="*"/>
           </Grid.ColumnDefinitions>

           <!-- ══════════════════════════════════
                SIDEBAR
                ══════════════════════════════════ -->
           <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" CornerRadius="8,0,0,8"
                   BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,1,0">
               <Grid Margin="10">
                   <Grid.RowDefinitions>
                       <RowDefinition Height="Auto"/>
                       <RowDefinition Height="*"/>
                   </Grid.RowDefinitions>

                   <!-- Sidebar header -->
                   <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                           CornerRadius="6" Padding="12,10">
                       <Grid>
                           <Grid.ColumnDefinitions>
                               <ColumnDefinition Width="*"/>
                               <ColumnDefinition Width="Auto"/>
                           </Grid.ColumnDefinitions>
                           <StackPanel>
                               <TextBlock Text="SESSIONS" Foreground="{StaticResource TextPrimaryBrush}"
                                          FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                               <TextBlock Text="Saved design chats" Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap"/>
                           </StackPanel>
                           <Button x:Name="SidebarNewChatBtn"
                                   Grid.Column="1"
                                   Width="30" Height="30"
                                   Margin="8,0,0,0"
                                   Content="+"
                                   FontSize="16"
                                   Background="{StaticResource AccentBrush}"
                                   Foreground="#1A1200"
                                   BorderThickness="0"
                                   Cursor="Hand"
                                   Click="ClearChatButton_Click"
                                   ToolTip="Start New Chat"
                                   Style="{StaticResource PrimaryButtonStyle}"/>
                       </Grid>
                   </Border>

                   <!-- Session list -->
                   <Border Grid.Row="1" Margin="0,10,0,0" Background="#1E1E1E" BorderBrush="#333333"
                           BorderThickness="1" CornerRadius="6">
                       <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                           <StackPanel x:Name="HistoryListPanel"/>
                       </ScrollViewer>
                   </Border>
               </Grid>
           </Border>

           <!-- Divider -->
           <Rectangle Grid.Column="1" Fill="#333333"/>

           <!-- ══════════════════════════════════
                MAIN AREA
                ══════════════════════════════════ -->
           <Grid Grid.Column="2">
               <Grid.RowDefinitions>
                   <RowDefinition Height="Auto"/>
                   <RowDefinition Height="*"/>
               </Grid.RowDefinitions>

               <!-- ── Header bar ── -->
               <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                       BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,0,1"
                       CornerRadius="0,8,0,0">
                   <!-- Amber top-edge accent line -->
                   <Grid>
                       <Grid.RowDefinitions>
                           <RowDefinition Height="2"/>
                           <RowDefinition Height="Auto"/>
                       </Grid.RowDefinitions>
                       <Rectangle Grid.Row="0" Fill="{StaticResource AccentBrush}" RadiusX="0" RadiusY="0"
                                  HorizontalAlignment="Stretch"/>
                       <Grid Grid.Row="1" Margin="16,12">
                           <Grid.ColumnDefinitions>
                               <ColumnDefinition Width="*"/>
                               <ColumnDefinition Width="Auto"/>
                           </Grid.ColumnDefinitions>

                           <!-- Agent identity -->
                           <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                               <Border Width="38" Height="38" CornerRadius="6"
                                       Background="#272727" BorderBrush="#3A3A3A" BorderThickness="1">
                                   <TextBlock Text="⚙" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              FontSize="18" Foreground="{StaticResource AccentBrush}"/>
                               </Border>
                               <StackPanel Margin="10,0,0,0">
                                   <TextBlock Text="AI CAD AGENT" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="13" FontWeight="Bold" LetterSpacing="1.2"/>
                                   <TextBlock Text="Civil 3D automation · natural language" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                               </StackPanel>
                           </StackPanel>

                           <!-- Tab buttons -->
                           <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                               <Button x:Name="TabChatButton"
                                       Content="CHAT"
                                       FontSize="11"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,6,0"
                                       Click="TabChatButton_Click"
                                       Style="{StaticResource TopTabButtonStyle}"/>
                               <Button x:Name="TabSettingsButton"
                                       Content="SETTINGS"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Click="TabSettingsButton_Click"
                                       Style="{StaticResource TopTabButtonStyle}"/>
                           </StackPanel>
                       </Grid>
                   </Grid>
               </Border>

               <!-- ══════════════════════════════════
                    CHAT TAB
                    ══════════════════════════════════ -->
               <Grid x:Name="ChatTab" Grid.Row="1" Visibility="Visible" Margin="14,12,14,14">
                   <Grid.RowDefinitions>
                       <RowDefinition Height="Auto"/>
                       <RowDefinition Height="*"/>
                       <RowDefinition Height="Auto"/>
                   </Grid.RowDefinitions>

                   <!-- Context banner — left amber strip -->
                   <Border Grid.Row="0" Background="#232323" BorderBrush="#333333" BorderThickness="1"
                           CornerRadius="6" Margin="0,0,0,10">
                       <Grid>
                           <!-- Amber left strip -->
                           <Rectangle Width="3" HorizontalAlignment="Left" Fill="{StaticResource AccentBrush}" RadiusX="3" RadiusY="3"/>
                           <Grid Margin="14,10">
                               <Grid.ColumnDefinitions>
                                   <ColumnDefinition Width="*"/>
                                   <ColumnDefinition Width="Auto"/>
                               </Grid.ColumnDefinitions>
                               <StackPanel>
                                   <TextBlock Text="CIVIL 3D CHAT INTERFACE" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
                                   <TextBlock Text="Describe alignments, surfaces, profiles, corridors, or cleanup actions. The agent translates them into Civil 3D operations."
                                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
                               </StackPanel>
                               <!-- Live indicator -->
                               <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0,0,0">
                                   <Ellipse Width="7" Height="7" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                   <TextBlock Text="LIVE" Foreground="{StaticResource SuccessBrush}"
                                              FontWeight="Bold" FontSize="10" VerticalAlignment="Center" LetterSpacing="1"/>
                               </StackPanel>
                           </Grid>
                       </Grid>
                   </Border>

                   <!-- Chat history area -->
                   <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1" CornerRadius="6">
                       <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Padding="12">
                           <StackPanel x:Name="ChatHistoryPanel" VerticalAlignment="Bottom"/>
                       </ScrollViewer>
                   </Border>

                   <!-- Input area -->
                   <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                           CornerRadius="6" Padding="10" Margin="0,10,0,0">
                       <Grid>
                           <Grid.ColumnDefinitions>
                               <ColumnDefinition Width="*"/>
                               <ColumnDefinition Width="Auto"/>
                           </Grid.ColumnDefinitions>
                           <Grid.RowDefinitions>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="Auto"/>
                           </Grid.RowDefinitions>

                           <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="PROMPT"
                                      Style="{StaticResource SectionLabelStyle}"/>

                           <TextBox x:Name="UserInputBox"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource InputTextBoxStyle}"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    MaxHeight="100"
                                    VerticalScrollBarVisibility="Auto"
                                    KeyDown="UserInputBox_KeyDown"/>

                           <Button x:Name="SendButton"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Width="64"
                                   Margin="10,0,0,0"
                                   Content="SEND"
                                   FontSize="11"
                                   Click="SendButton_Click"
                                   VerticalAlignment="Bottom"
                                   Style="{StaticResource PrimaryButtonStyle}"/>
                       </Grid>
                   </Border>
               </Grid>

               <!-- ══════════════════════════════════
                    SETTINGS TAB
                    ══════════════════════════════════ -->
               <ScrollViewer x:Name="SettingsTab" Grid.Row="1" Visibility="Collapsed"
                             Margin="14,12,14,14" VerticalScrollBarVisibility="Auto">
                   <StackPanel>
                       <!-- Settings heading banner -->
                       <Border Background="#232323" BorderBrush="#333333" BorderThickness="1"
                               CornerRadius="6" Margin="0,0,0,10">
                           <Grid>
                               <Rectangle Width="3" HorizontalAlignment="Left" Fill="{StaticResource AccentBrush}" RadiusX="3" RadiusY="3"/>
                               <StackPanel Margin="14,12">
                                   <TextBlock Text="SETTINGS" Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="11" FontWeight="Bold" LetterSpacing="1.2"/>
                                   <TextBlock Text="Configure model access and validate API connections used by the Civil 3D chat panel."
                                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
                               </StackPanel>
                           </Grid>
                       </Border>

                       <!-- MCP Server -->
                       <Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                               CornerRadius="6" Padding="14" Margin="0,0,0,10">
                           <StackPanel>
                               <TextBlock Text="MCP SERVER" Style="{StaticResource SectionLabelStyle}" LetterSpacing="1"/>
                               <TextBlock Text="Connects the AI to your live Civil 3D drawing. Start the Node.js server before use."
                                          Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"/>
                               <TextBlock Text="SERVER URL" Style="{StaticResource SectionLabelStyle}" LetterSpacing="1"/>
                               <TextBox x:Name="McpServerUrlBox"
                                        Style="{StaticResource InputTextBoxStyle}"
                                        Margin="0,0,0,10"/>
                               <Grid>
                                   <Grid.ColumnDefinitions>
                                       <ColumnDefinition Width="Auto"/>
                                       <ColumnDefinition Width="*"/>
                                   </Grid.ColumnDefinitions>
                                   <Button x:Name="ReconnectMcpBtn"
                                           Grid.Column="0"
                                           Content="Reconnect"
                                           Click="ReconnectMcpBtn_Click"
                                           Style="{StaticResource SecondaryButtonStyle}"/>
                                   <TextBlock x:Name="McpStatusText"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"
                                              FontSize="12"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                               </Grid>
                           </StackPanel>
                       </Border>

                       <!-- Playwright MCP Server -->
                       <Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                               CornerRadius="6" Padding="14" Margin="0,0,0,10">
                           <StackPanel>
                               <TextBlock Text="PLAYWRIGHT MCP SERVER" Style="{StaticResource SectionLabelStyle}" LetterSpacing="1"/>
                               <TextBlock Text="Enables the AI to browse the web, look up engineering standards, and interact with web portals. Run your Playwright MCP server before connecting."
                                          Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"/>
                               <TextBlock Text="SERVER URL" Style="{StaticResource SectionLabelStyle}" LetterSpacing="1"/>
                               <TextBox x:Name="PlaywrightUrlBox"
                                        Style="{StaticResource InputTextBoxStyle}"
                                        Margin="0,0,0,10"/>
                               <Grid>
                                   <Grid.ColumnDefinitions>
                                       <ColumnDefinition Width="Auto"/>
                                       <ColumnDefinition Width="*"/>
                                   </Grid.ColumnDefinitions>
                                   <Button x:Name="ReconnectPlaywrightBtn"
                                           Grid.Column="0"
                                           Content="Reconnect"
                                           Click="ReconnectPlaywrightBtn_Click"
                                           Style="{StaticResource SecondaryButtonStyle}"/>
                                   <TextBlock x:Name="PlaywrightStatusText"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"
                                              FontSize="12"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                               </Grid>
                           </StackPanel>
                       </Border>

                       <!-- AI Provider -->
                       <Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                               CornerRadius="6" Padding="14">
                           <StackPanel>
                               <TextBlock Text="AI PROVIDER / MODEL" Style="{StaticResource SectionLabelStyle}" LetterSpacing="1"/>
                               <ComboBox x:Name="ProviderCombo"
                                         Background="#272727"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="#3A3A3A"
                                         Padding="8"
                                         Margin="0,0,0,14"
                                         SelectionChanged="ProviderCombo_SelectionChanged"
                                         ItemContainerStyle="{StaticResource DarkComboItemStyle}">
                                   <ComboBoxItem Content="Google Gemini (2.5 Flash)" Tag="gemini:gemini-2.5-flash" IsSelected="True"/>
                                   <ComboBoxItem Content="Google Gemini (3.1 Pro)" Tag="gemini:gemini-3.1-pro"/>
                                   <ComboBoxItem Content="OpenAI (GPT-4o Mini)" Tag="openai:gpt-4o-mini"/>
                                   <ComboBoxItem Content="OpenAI (GPT-4o)" Tag="openai:gpt-4o"/>
                                   <ComboBoxItem Content="OpenAI (GPT-5.4)" Tag="openai:gpt-5.4"/>
                                   <ComboBoxItem Content="Anthropic Claude Sonnet 4.5" Tag="anthropic:claude-sonnet-4-5"/>
                                   <ComboBoxItem Content="Anthropic Claude Sonnet 4.6" Tag="anthropic:claude-sonnet-4-6"/>
                                   <ComboBoxItem Content="Anthropic Claude Opus 4.5" Tag="anthropic:claude-opus-4-5"/>
                                   <ComboBoxItem Content="Anthropic Claude Opus 4.6" Tag="anthropic:claude-opus-4-6"/>
                               </ComboBox>

                               <TextBlock Text="API KEY" Style="{StaticResource SectionLabelStyle}" LetterSpacing="1"/>
                               <TextBox x:Name="ApiKeyBox"
                                        Style="{StaticResource InputTextBoxStyle}"
                                        Margin="0,0,0,14"/>

                               <TextBlock Text="OPENAI VECTOR STORE ID (OPTIONAL)" Style="{StaticResource SectionLabelStyle}" LetterSpacing="1"/>
                               <TextBlock Text="Paste your vector store ID to enable file search against uploaded Autodesk API documentation. Applies to OpenAI models only."
                                          Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                               <TextBox x:Name="VectorStoreIdBox"
                                        Style="{StaticResource InputTextBoxStyle}"
                                        Margin="0,0,0,14"/>

                               <Grid>
                                   <Grid.ColumnDefinitions>
                                       <ColumnDefinition Width="Auto"/>
                                       <ColumnDefinition Width="*"/>
                                   </Grid.ColumnDefinitions>
                                   <Button x:Name="TestConnectionBtn"
                                           Grid.Column="0"
                                           Content="Test Connection"
                                           Click="TestConnectionBtn_Click"
                                           Style="{StaticResource SecondaryButtonStyle}"/>
                                   <TextBlock x:Name="ConnectionStatusText"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"
                                              FontSize="12"
                                              Foreground="{StaticResource SuccessBrush}"/>
                               </Grid>
                           </StackPanel>
                       </Border>
                   </StackPanel>
               </ScrollViewer>
           </Grid>
       </Grid>
   </Border>
</UserControl>
