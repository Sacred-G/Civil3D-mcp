<UserControl x:Class="Cad_AI_Agent.UI.AIChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="560"
             Background="#0F172A"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#111827"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="CardBrush" Color="#162033"/>
        <SolidColorBrush x:Key="CardAltBrush" Color="#1B263B"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#243248"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#38BDF8"/>
        <SolidColorBrush x:Key="AccentBrushDark" Color="#0284C7"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E5EEF9"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#86EFAC"/>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#273449"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopTabButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="#172033"
                                BorderBrush="#22324A"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D2940"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22324A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrushDark}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0EA5E9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0369A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#172033"/>
            <Setter Property="BorderBrush" Value="#22324A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0F1A2E"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#2A3A55"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DarkComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#162033"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22324A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrushDark}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="16" Padding="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" x:Name="SidebarColumn"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" CornerRadius="16,0,0,16" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,1,0">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#101A2E" BorderBrush="#1F2A40" BorderThickness="1" CornerRadius="14" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Conversations" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="Switch between saved design chats" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button x:Name="SidebarNewChatBtn"
                                    Grid.Column="1"
                                    Width="34"
                                    Height="34"
                                    Margin="12,0,0,0"
                                    Content="+"
                                    FontSize="18"
                                    Background="{StaticResource AccentBrushDark}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="ClearChatButton_Click"
                                    ToolTip="Start New Chat"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Margin="0,14,0,0" Background="#101A2E" BorderBrush="#1F2A40" BorderThickness="1" CornerRadius="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                            <StackPanel x:Name="HistoryListPanel"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#1F2A40" Cursor="SizeWE"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,0,1" CornerRadius="0,16,0,0">
                    <Grid Margin="18,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="44" Height="44" CornerRadius="12" Background="#10243A" BorderBrush="#1F3B59" BorderThickness="1">
                                <TextBlock Text="✦" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="AI CAD Agent" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Design and automate Civil 3D workflows from natural language" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="TabChatButton"
                                    Content="Chat"
                                    Foreground="{StaticResource AccentBrush}"
                                    Margin="0,0,8,0"
                                    Click="TabChatButton_Click"
                                    Style="{StaticResource TopTabButtonStyle}"/>
                            <Button x:Name="TabSettingsButton"
                                    Content="Settings"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Click="TabSettingsButton_Click"
                                    Style="{StaticResource TopTabButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="ChatTab" Grid.Row="1" Visibility="Visible" Margin="18,16,18,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#122034" BorderBrush="#22324A" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Chat inside Civil 3D" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="Describe alignments, surfaces, profiles, corridors, or cleanup actions. The agent will translate that into Civil 3D operations." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#0E2A3C" BorderBrush="#174A6A" BorderThickness="1" CornerRadius="999" Padding="10,6" VerticalAlignment="Top">
                                <TextBlock Text="Live Session" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="11"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#101A2E" BorderBrush="#1F2A40" BorderThickness="1" CornerRadius="16">
                        <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Padding="14">
                            <StackPanel x:Name="ChatHistoryPanel" VerticalAlignment="Bottom"/>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="2" Background="#101A2E" BorderBrush="#1F2A40" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Prompt" Style="{StaticResource SectionLabelStyle}"/>

                            <TextBox x:Name="UserInputBox"
                                     Grid.Row="1"
                                     Grid.Column="0"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MaxHeight="120"
                                     VerticalScrollBarVisibility="Auto"
                                     KeyDown="UserInputBox_KeyDown"/>

                            <Button x:Name="SendButton"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Width="72"
                                    Margin="12,0,0,0"
                                    Content="Send"
                                    Click="SendButton_Click"
                                    VerticalAlignment="Bottom"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </Grid>
                    </Border>
                </Grid>

                <ScrollViewer x:Name="SettingsTab" Grid.Row="1" Visibility="Collapsed" Margin="18,16,18,18" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#122034" BorderBrush="#22324A" BorderThickness="1" CornerRadius="16" Padding="18" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="AI Settings" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Configure model access and validate the API connection used by the Civil 3D chat panel." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#101A2E" BorderBrush="#1F2A40" BorderThickness="1" CornerRadius="16" Padding="18">
                            <StackPanel>
                                <TextBlock Text="AI Provider" Style="{StaticResource SectionLabelStyle}"/>
                                <ComboBox x:Name="ProviderCombo"
                                          Background="#0F1A2E"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderBrush="#2A3A55"
                                          Padding="8"
                                          Margin="0,0,0,18"
                                          ItemContainerStyle="{StaticResource DarkComboItemStyle}">
                                    <ComboBoxItem Content="Google Gemini (2.5 Flash)" Tag="gemini-2.5-flash" IsSelected="True"/>
                                    <ComboBoxItem Content="Google Gemini (3.1 Pro)" Tag="gemini-3.1-pro"/>
                                    <ComboBoxItem Content="OpenAI (ChatGPT) - Coming Soon" IsEnabled="False"/>
                                </ComboBox>

                                <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                <TextBox x:Name="ApiKeyBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Margin="0,0,0,18"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="TestConnectionBtn"
                                            Grid.Column="0"
                                            Content="Test Connection"
                                            Click="TestConnectionBtn_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                    <TextBlock x:Name="ConnectionStatusText"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"
                                               FontSize="13"
                                               Foreground="{StaticResource SuccessBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>